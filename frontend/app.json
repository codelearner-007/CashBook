{
  "expo": {
    "name": "CashBook",
    "slug": "cashbook",
    "scheme": "cashbook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#3B5BDB"
    },
    "android": {
      "package": "com.yourname.cashbook",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3B5BDB"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [{ "scheme": "cashbook" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "ios": {
      "bundleIdentifier": "com.yourname.cashbook",
      "infoPlist": {
        "NSCameraUsageDescription": "CashBook uses your camera to set a profile photo.",
        "NSPhotoLibraryUsageDescription": "CashBook accesses your photo library to set a profile photo."
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "CashBook accesses your photos to set a profile photo.",
          "cameraPermission": "CashBook uses your camera to take a profile photo."
        }
      ]
    ]
  }
}
